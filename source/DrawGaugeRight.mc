    static function draw(dc as Graphics.Dc, cx as Number, cy as Number,
                         screenW as Number, progress as Float) as Void {
        var s = screenW.toFloat() / 1000.0 * Constants.GAUGE_EDGE_SCALE;

        for (var i = 0; i < SCALE.size(); i += 1) {
            var l = SCALE[i];
            var pw = (l[5] * s + 0.5).toNumber();
            if (pw < 1) { pw = 1; }
            dc.setPenWidth(pw);
            dc.setColor(l[4], Graphics.COLOR_TRANSPARENT);
            dc.drawLine(cx + (l[0] - 500.0) * s, cy + (l[1] - 500.0) * s,
                        cx + (l[2] - 500.0) * s, cy + (l[3] - 500.0) * s);
        }

        var n = PROGRESS.size();
        var filled = (progress * n + 0.5).toNumber();
        if (filled > n) { filled = n; }
        var pwp = (3.0 * s + 0.5).toNumber();
        if (pwp < 1) { pwp = 1; }
        dc.setPenWidth(pwp);
        for (var i = 0; i < n; i += 1) {
            var l = PROGRESS[i];
            var col;
            if (i < filled) {
                var t = (filled > 1) ? i.toFloat() / (filled - 1).toFloat() : 0.0;
                col = lerpColor(Constants.COLOR_GAUGE_FILLED_TOP, Constants.COLOR_GAUGE_FILLED_BOT, t);
            } else {
                col = Constants.COLOR_GAUGE_EMPTY;
            }
            dc.setColor(col, Graphics.COLOR_TRANSPARENT);
            dc.drawLine(cx + (l[0] - 500.0) * s, cy + (l[1] - 500.0) * s,
                        cx + (l[2] - 500.0) * s, cy + (l[3] - 500.0) * s);
        }
        dc.setPenWidth(1);
    }

    private static function lerpColor(c0 as Number, c1 as Number, t as Float) as Number {
        if (t < 0.0) { t = 0.0; }
        if (t > 1.0) { t = 1.0; }
        var r0 = (c0 >> 16) & 0xFF; var g0 = (c0 >> 8) & 0xFF; var b0 = c0 & 0xFF;
        var r1 = (c1 >> 16) & 0xFF; var g1 = (c1 >> 8) & 0xFF; var b1 = c1 & 0xFF;
        var r = (r0 + (r1 - r0) * t).toNumber();
        var g = (g0 + (g1 - g0) * t).toNumber();
        var b = (b0 + (b1 - b0) * t).toNumber();
        return (r << 16) | (g << 8) | b;
    }
}
