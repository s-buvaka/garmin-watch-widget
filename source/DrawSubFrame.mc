    static function draw(dc as Graphics.Dc, cx as Number, cy as Number,
                         screenW as Number, dayProgress as Float) as Void {
        var subR  = screenW * Constants.SUB_DIAL_RADIUS;
        var subCy = cy + (screenW * (Constants.SUB_DIAL_CY_OFFSET + Constants.FRAME_Y_OFFSET));
        var k = subR * Constants.FRAME_FIT / 436.0;

        dc.setColor(Constants.COLOR_FRAME_OUTLINE, Graphics.COLOR_TRANSPARENT);
        dc.setPenWidth(1);
        dc.drawArc(cx, subCy, (384.0 * k).toNumber(), Graphics.ARC_COUNTER_CLOCKWISE, 305.0, 235.0);

        var n = SEG.size();
        var filled = (dayProgress * n + 0.5).toNumber();
        if (filled > n) { filled = n; }
        var pw = (3.2 * k + 0.5).toNumber();
        if (pw < 1) { pw = 1; }
        dc.setPenWidth(pw);
        for (var i = 0; i < n; i += 1) {
            var l = SEG[i];
            var col;
            if (i < filled) {
                var t = (filled > 1) ? i.toFloat() / (filled - 1).toFloat() : 0.0;
                col = lerpColor(Constants.COLOR_GAUGE_FILLED_TOP, Constants.COLOR_GAUGE_FILLED_BOT, t);
            } else {
                col = Constants.COLOR_FRAME_EMPTY;
            }
            dc.setColor(col, Graphics.COLOR_TRANSPARENT);
            dc.drawLine(cx + (l[0] - 500.0) * k, subCy + (l[1] - 500.0) * k,
                        cx + (l[2] - 500.0) * k, subCy + (l[3] - 500.0) * k);
        }
        dc.setPenWidth(1);
    }

    private static function lerpColor(c0 as Number, c1 as Number, t as Float) as Number {
        if (t < 0.0) { t = 0.0; }
        if (t > 1.0) { t = 1.0; }
        var r0 = (c0 >> 16) & 0xFF; var g0 = (c0 >> 8) & 0xFF; var b0 = c0 & 0xFF;
        var r1 = (c1 >> 16) & 0xFF; var g1 = (c1 >> 8) & 0xFF; var b1 = c1 & 0xFF;
        var r = (r0 + (r1 - r0) * t).toNumber();
        var g = (g0 + (g1 - g0) * t).toNumber();
        var b = (b0 + (b1 - b0) * t).toNumber();
        return (r << 16) | (g << 8) | b;
    }
}
